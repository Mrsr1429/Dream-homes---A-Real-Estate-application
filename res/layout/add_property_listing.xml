<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    tools:context=".screens.AddPropertyActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Header with Back Button -->
            <ImageButton
                android:id="@+id/back_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:src="@drawable/back_button"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/headings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Add Your Property"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Form Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/form_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_background"
                app:layout_constraintTop_toBottomOf="@+id/headings"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/background_light"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <EditText
                            android:id="@+id/property_location"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Property Location"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:padding="16dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Property Type Dropdown -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/background_light"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:hint="Property Type">

                        <AutoCompleteTextView
                            android:id="@+id/property_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Select Type (Sell or Rent)"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:padding="16dp"
                            android:inputType="none" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/background_light"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <EditText
                            android:id="@+id/property_shortdescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Property Title"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:padding="16dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/background_light"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <EditText
                            android:id="@+id/property_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Description"
                            android:inputType="textMultiLine"
                            android:minLines="3"
                            android:maxLines="5"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:padding="16dp"
                            android:gravity="top" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/background_light"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <EditText
                            android:id="@+id/property_ownername"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Owner Name"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:padding="16dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/background_light"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <EditText
                            android:id="@+id/property_contactno"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Contact Number"
                            android:inputType="phone"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:padding="16dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/background_light"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <EditText
                            android:id="@+id/property_price"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Price (e.g., ₹50 Lakh or ₹2.5 Cr or ₹25,000/month)"
                            android:inputType="text"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:padding="16dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Property Category Dropdown -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/background_light"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:hint="Category">

                        <AutoCompleteTextView
                            android:id="@+id/property_category"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Select Category"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:padding="16dp"
                            android:inputType="none" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Additional Property Details Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Property Details"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp" />

                    <!-- Bedrooms -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/background_light"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <EditText
                            android:id="@+id/property_bedrooms"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Number of Bedrooms"
                            android:inputType="number"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:padding="16dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Bathrooms -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/background_light"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <EditText
                            android:id="@+id/property_bathrooms"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Number of Bathrooms"
                            android:inputType="number"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:padding="16dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Area/Size -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/background_light"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <EditText
                            android:id="@+id/property_area"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Area (sq ft or sq m)"
                            android:inputType="number"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:padding="16dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Year Built (Optional) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/background_light"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <EditText
                            android:id="@+id/property_year"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Year Built (Optional)"
                            android:inputType="number"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:padding="16dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Image Preview -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp">

                        <ImageView
                            android:id="@+id/imageViewUploaded"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/hom1"
                            android:background="@color/light_grey" />

                    </androidx.cardview.widget.CardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonUploadImage"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Add Image"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@color/primary"
                        android:textColor="@color/white"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Add Property"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@color/accent"
                        android:textColor="@color/white" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
